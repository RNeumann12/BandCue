{
  "manifest_version": 3,
  "name": "BandCue Songsterr Adapter",
  "version": "1.0.1",
  "description": "Connect Songsterr tabs to a local BandCue rehearsal room.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["https://www.songsterr.com/*", "https://songsterr.com/*", "http://*/*", "ws://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BandCue",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.songsterr.com/*", "https://songsterr.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
